# Copy to .env and fill in. Never commit .env (gitignored).

# --- API ---
PORT=3001
NODE_ENV=development

# --- Database (matches docker-compose.yml) ---
# Migrations run as this superuser; the app runtime connects as a non-superuser
# app role so RLS applies (see docs/conventions/data-model.md).
DATABASE_URL=postgres://agentgit:agentgit@localhost:5432/agentgit
# Used by package DB RLS tests when the app role password differs from local dev.
AGENTGIT_APP_DB_PASSWORD=agentgit_app

# --- Event bus (NATS JetStream) ---
NATS_URL=nats://localhost:4222

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- GitHub App (F1) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- LLM (diagnosis agent, F8) ---
ANTHROPIC_API_KEY=
